import pytesseract
pytesseract.pytesseract.tesseract_cmd = r"C:\Program Files\Tesseract-OCR\tesseract.exe"

from flask import Flask, request, render_template
import os
from PIL import Image, ImageFilter, ImageOps

app = Flask(__name__)
app.config['UPLOAD_FOLDER'] = 'uploads'

@app.route('/')
def home():
    return render_template('index.html')

@app.route('/upload', methods=['POST'])
def upload_file():
    if 'file' not in request.files:
        return "No file part"
    file = request.files['file']
    if file.filename == '':
        return "No selected file"
    filepath = os.path.join(app.config['UPLOAD_FOLDER'], file.filename)
    file.save(filepath)

    # OCR extract text with preprocessing
    try:
        img = Image.open(filepath)
        img = img.convert("L")  # grayscale
        img = img.filter(ImageFilter.SHARPEN)  # sharpen edges
        text = pytesseract.image_to_string(img, config="--psm 6")
    except Exception as e:
        text = f"Error extracting text: {str(e)}"

    # Keyword check (Tamil Nadu universities only)
    status = "❌ Fake Certificate"

    tn_universities = [
        "Anna University", "University of Madras", "Bharathiar University",
        "Bharathidasan University", "Periyar University", "Tamil Nadu Agricultural University",
        "Tamil Nadu Dr. M.G.R. Medical University", "Alagappa University",
        "Manonmaniam Sundaranar University", "Mother Teresa University",
        "Tamil University", "Annamalai University"
    ]

    if any(word.lower() in text.lower() for word in tn_universities):
        status = "✅ Valid Certificate"
    else:
        status = "❌ Fake Certificate"

    return render_template(
        'result.html',
        filename=file.filename,
        status=status,
        content=text
    )

if __name__ == '__main__':
    if not os.path.exists(app.config['UPLOAD_FOLDER']):
        os.makedirs(app.config['UPLOAD_FOLDER'])
    app.run(debug=True)
